<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Jirando</title>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="css/style.css">
</head>
<body>

  <!-- Header Placeholder -->
  <div id="header-placeholder"></div>

  <!-- Hero Section -->
  <section id="hero" style="position: relative;">
    <div style="text-align:center; padding: 100px 20px;">
      <h1 class="hero-title">Jirando</h1>
      <h5 style="color: var(--primary);">por HDR Soluciones en TI</h5>
      
      <h2 class="lang es active">Consultoría Especializada en Soluciones Atlassian</h2>
      <p class="lang es active hero-desc">
        Transformamos la forma en que su equipo trabaja con soluciones Atlassian.
      </p>
      <a href="#contact">Contáctanos</a>
    </div>
  </section>

  <!-- About Section -->
  <section id="about">
    <h2 class="lang es active">Sobre Jirando</h2>
    <div class="about-content">
      <div class="about-block">
        <img src="images/content/about/strategic_partner.jpg" alt="Socio Estratégico" style="width:100%; height:auto; margin-bottom:10px;">
        <h3>Socio Estratégico</h3>
        <p class="lang es active">
          Jirando se posiciona como un socio estratégico para empresas que buscan obtener el máximo valor de las soluciones Atlassian.
        </p>
      </div>
      <div class="about-block">
        <img src="images/content/about/consult.jpg"  alt="Consultoría e Integración" style="width:100%; height:auto; margin-bottom:10px;">
        <h3>Consultoría, Implementación e Integración</h3>
        <p class="lang es active">
          La consultoría, implementación e integración garantizan un ecosistema escalable y actualizado.
        </p>
      </div>
      <div class="about-block">
        <img src="images/content/about/dig_transform.jpg" alt="Transformación Digital" style="width:100%; height:auto; margin-bottom:10px;">
        <h3>Transformación Digital</h3>
        <p class="lang es active">
          Experiencia en Jira, Confluence, Trello, Bitbucket y otras herramientas Atlassian para impulsar la innovación.
        </p>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services">
    <h2 class="lang es active">Servicios y Tecnologías</h2>
    <div class="grid">
      <div class="card">
        <img src="images/content/services/jira.jpg" alt="Ícono Jira Software" style="width:50px; height:50px;">
        <h3>Jira Software</h3>
        <p>Implementación y personalización con metodologías ágiles como Scrum y Kanban.</p>
      </div>
      <div class="card">
        <img src="images/content/services/confluence.jpg" alt="Ícono Confluence" style="width:50px; height:50px;">
        <h3>Confluence</h3>
        <p>Organización de wikis, manuales e informes integrados con Jira.</p>
      </div>
      <div class="card">
        <img src="images/content/services/jsm.jpg" alt="Ícono Jira Service Management" style="width:50px; height:50px;">
        <h3>Jira Service Management</h3>
        <p>Gestión de servicios con flujos personalizados y paneles de métricas.</p>
      </div>
      <div class="card">
        <img src="images/content/services/others.jpg" alt="Otras Herramientas Atlassian" style="width:50px; height:50px;">
        <h3>Otras Herramientas Atlassian</h3>
        <p>Consultoría en Trello, Bitbucket, Opsgenie y Statuspage.</p>
      </div>
      <div class="card">
        <img src="images/content/services/devops_itil.jpg" alt="Ícono DevOps" style="width:50px; height:50px;">
        <h3>DevOps e ITIL</h3>
        <p>Integración de prácticas ágiles con marcos de gobernanza para la innovación.</p>
      </div>
    </div>
  </section>

<!-- Success Section -->
  <section id="success">
    <h2 class="lang es active">Casos de Éxito</h2>
    <div class="grid">
      <div class="card">
        <img src="images/content/cases/jira_update.jpg" alt="Actualización Jira Server" style="width:40%; height:auto; margin-bottom:10px;">
        <h4>Actualización de Jira Server y de las versiones de la base de datos, garantizando compatibilidad, estabilidad y mejor rendimiento</h4>
      </div>
      <div class="card">
        <img src="images/content/cases/m2c.jpg" alt="Migración a Jira Cloud" style="width:40%; height:auto; margin-bottom:10px;">
        <h4>Migración de Jira DataCenter/Server (on-premises) a Jira Cloud para cumplir con el ciclo de fin de vida de Atlassian</h4>
      </div>
      <div class="card">
        <img src="images/content/cases/jira_conf_pbi.jpg" alt="JSM y Power BI" style="width:40%; height:auto; margin-bottom:10px;">
        <h4>Implementación de Jira Service Management e integración con Confluence y reportes en Power BI</h4>
      </div>
      <div class="card">
        <img src="images/content/cases/dash.jpg" alt="Métricas Jira Cloud" style="width:40%; height:auto; margin-bottom:10px;">
        <h4>Implementación de métricas en Jira Cloud/JSM con paneles en Power BI</h4>
      </div>
      <div class="card">
        <img src="images/content/cases/jira_jsm.jpg" alt="Integración JSM y Cloud" style="width:40%; height:auto; margin-bottom:10px;">
        <h4>Integración entre Jira Service Management y Jira Cloud</h4>
      </div>
       <div class="card">
        <img src="images/content/cases/rest.jpg" alt="Reestructuración" style="width:40%; height:auto; margin-bottom:10px;">
        <h4>Reestructuración de Jira Cloud y Jira Service Management, alineándose con las mejores prácticas en gobernanza, atención al cliente y gestión de procesos</h4>
      </div>
    </div>
  </section>

  </form>
    <p style="margin-top:20px; text-align:center; font-weight:bold;">
    </p>

    <!-- Clients Section -->
  <section id="clients">
    <h2 class="lang en active">Nuestros Clientes</h2>
    <div class="grid">
      
      <div class="card">
        <img src="images/content/clients/acra.jpg" alt="Client 1 Logo">
      </div>

      <div class="card">
        <img src="images/content/clients/caixa.jpg" alt="Client 2 Logo">
      </div>

      <div class="card">
        <img src="images/content/clients/tenda.jpg" alt="Client 3 Logo">
      </div>

    </div>
  </section>

   </form>
    <p style="margin-top:35px; text-align:center; font-weight:bold;">
    </p>

<!-- Contact Section -->
<section id="contact" style="position:relative;">
  <h2 class="lang en active">Contact</h2>

  <!-- Contact Form -->
  <form id="contactForm">
    <input type="text" id="name" placeholder="Nombre" required>
    <input type="email" id="email" placeholder="Email" required>
    <textarea id="message" rows="5" placeholder="Mensaje" required></textarea>
    
    <!-- Send Button with type="submit" -->
    <button type="submit" class="btn">Enviar</button>
  </form>

 <!-- Mail and phone--> 
     <p style="margin-top:20px; text-align:center; font-weight:bold;">
      Telefóno: +55 (31) 991400841
    </p>
     <p class="email-container">
      Email: <a href="mailto:contato@jirando.com" class="cool-blue-link">contato@jirando.com</a>
    </p>

  <!-- WhatsApp Floating Icon -->
  <a href="https://wa.me/5531991400841" target="_blank" class="whatsapp-float">
    <img src="https://upload.wikimedia.org/wikipedia/commons/6/6b/WhatsApp.svg" alt="WhatsApp" />
  </a>

  <!-- Footer Placeholder -->
  <div id="footer-placeholder"></div>

  <script src="https://cdn.emailjs.com/dist/email.min.js"></script>
  <script src="js/main.js"></script>
  <script src="js/email.js"></script>
</body>
</html>