<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Jirando</title>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="css/style.css">
</head>
<body>

  <!-- Header Placeholder -->
  <div id="header-placeholder"></div>

  <!-- Hero Section -->
  <section id="hero" style="position: relative;">
    <div style="text-align:center; padding: 100px 20px;">
      <h1 class="hero-title">Jirando</h1>
      <h5 style="color: var(--primary);">por HDR Soluções em TI</h5>
      
      <h2 class="lang pt active">Consultoria Especializada em Soluções Atlassian</h2>
      <p class="lang pt active hero-desc">
        Transformamos a forma como sua equipe trabalha com soluções Atlassian.
      </p>
      <a href="#contact">Fale Conosco</a>
    </div>
  </section>

  <!-- About Section -->
  <section id="about">
    <h2 class="lang pt active">Sobre a Jirando</h2>
    <div class="about-content">
      <div class="about-block">
        <img src="images/content/about/strategic_partner.jpg" alt="Parceiro Estratégico" style="width:100%; height:auto; margin-bottom:10px;">
        <h3>Parceiro Estratégico</h3>
        <p class="lang pt active">
          A Jirando se posiciona como parceira estratégica para empresas que buscam extrair o máximo valor das soluções Atlassian.
        </p>
      </div>
      <div class="about-block">
        <img src="images/content/about/consult.jpg"  alt="Consultoria e Integração" style="width:100%; height:auto; margin-bottom:10px;">
        <h3>Consultoria, Implementação e Integração</h3>
        <p class="lang pt active">
          Consultoria, implementação e integração garantem um ecossistema escalável e atualizado.
        </p>
      </div>
      <div class="about-block">
        <img src="images/content/about/dig_transform.jpg" alt="Transformação Digital" style="width:100%; height:auto; margin-bottom:10px;">
        <h3>Transformação Digital</h3>
        <p class="lang pt active">
          Especialização em Jira, Confluence, Trello, Bitbucket e outras ferramentas Atlassian para impulsionar a inovação.
        </p>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services">
    <h2 class="lang pt active">Serviços e Tecnologias</h2>
    <div class="grid">
      <div class="card">
        <img src="images/content/services/jira.jpg" alt="Ícone Jira Software" style="width:50px; height:50px;">
        <h3>Jira Software</h3>
        <p>Implementação e customização com metodologias ágeis como Scrum e Kanban.</p>
      </div>
      <div class="card">
        <img src="images/content/services/confluence.jpg" alt="Ícone Confluence" style="width:50px; height:50px;">
        <h3>Confluence</h3>
        <p>Organização de wikis, manuais e relatórios integrados ao Jira.</p>
      </div>
      <div class="card">
        <img src="images/content/services/jsm.jpg" alt="Ícone Jira Service Management" style="width:50px; height:50px;">
        <h3>Jira Service Management</h3>
        <p>Gestão de serviços com fluxos personalizados e dashboards de métricas.</p>
      </div>
      <div class="card">
        <img src="images/content/services/others.jpg" alt="Outras Ferramentas Atlassian" style="width:50px; height:50px;">
        <h3>Outras Ferramentas Atlassian</h3>
        <p>Consultoria em Trello, Bitbucket, Opsgenie e Statuspage.</p>
      </div>
      <div class="card">
        <img src="images/content/services/devops_itil.jpg" alt="Ícone DevOps" style="width:50px; height:50px;">
        <h3>DevOps e ITIL</h3>
        <p>Integração de práticas ágeis com frameworks de governança para inovação.</p>
      </div>
    </div>
  </section>

  <!-- Success Section -->
  <section id="success">
    <h2 class="lang pt active">Casos de Sucesso</h2>
    <div class="grid">
      <div class="card">
        <img src="images/content/cases/jira_update.jpg" alt="Atualização Jira Server" style="width:40%; height:auto; margin-bottom:10px;">
        <h4>Atualização do Jira Server e das versões do banco de dados, garantindo compatibilidade, estabilidade e melhor desempenho.</h4>
      </div>
      <div class="card">
        <img src="images/content/cases/m2c.jpg" alt="Migração para Jira Cloud" style="width:40%; height:auto; margin-bottom:10px;">
        <h4>Migração do Jira DataCenter/Server (on-premises) para Jira Cloud para atender ao ciclo de fim de vida da Atlassian.</h4>
      </div>
      <div class="card">
        <img src="images/content/cases/jira_conf_pbi.jpg" alt="JSM e Power BI" style="width:40%; height:auto; margin-bottom:10px;">
        <h4>Implementação do Jira Service Management e integração com Confluence e relatórios no Power BI.</h4>
      </div>
      <div class="card">
        <img src="images/content/cases/dash.jpg" alt="Métricas Jira Cloud" style="width:40%; height:auto; margin-bottom:10px;">
        <h4>Implementação de métricas no Jira Cloud/JSM com dashboards no Power BI.</h4>
      </div>
      <div class="card">
        <img src="images/content/cases/jira_jsm.jpg" alt="Integração JSM e Cloud" style="width:40%; height:auto; margin-bottom:10px;">
        <h4>Integração entre Jira Service Management e Jira Cloud.</h4>
      </div>
       <div class="card">
        <img src="images/content/cases/rest.jpg" alt="Reestruturação" style="width:40%; height:auto; margin-bottom:10px;">
        <h4>Reestruturação do Jira Cloud e Jira Service Management, alinhando com as melhores práticas de governança, atendimento ao cliente e gestão de processos.</h4>
      </div>
    </div>
  </section>

   </form>
    <p style="margin-top:20px; text-align:center; font-weight:bold;">
    </p>
    <!-- Clients Section -->
  <section id="clients">
    <h2 class="lang en active">Nossos Clientes</h2>
    <div class="grid">
      
      <div class="card">
        <img src="images/content/clients/acra.jpg" alt="Client 1 Logo">
      </div>

      <div class="card">
        <img src="images/content/clients/caixa.jpg" alt="Client 2 Logo">
      </div>

      <div class="card">
        <img src="images/content/clients/tenda.jpg" alt="Client 3 Logo">
      </div>

    </div>
  </section>

   </form>
    <p style="margin-top:35px; text-align:center; font-weight:bold;">
    </p>

<!-- Contact Section -->
<section id="contact" style="position:relative;">
  <h2 class="lang en active">Contact</h2>

  <!-- Contact Form -->
  <form id="contactForm">
    <input type="text" id="name" placeholder="Nome" required>
    <input type="email" id="email" placeholder="Email" required>
    <textarea id="message" rows="5" placeholder="Mensagem" required></textarea>
    
    <!-- Send Button with type="submit" -->
    <button type="submit" class="btn">Enviar</button>
  </form>

 <!-- Mail and phone--> 
     <p style="margin-top:20px; text-align:center; font-weight:bold;">
      Telefone: +55 (31) 991400841
    </p>
     <p class="email-container">
      Email: <a href="mailto:contato@jirando.com" class="cool-blue-link">contato@jirando.com</a>
    </p>

  <!-- WhatsApp Floating Icon -->
  <a href="https://wa.me/5531991400841" target="_blank" class="whatsapp-float">
    <img src="https://upload.wikimedia.org/wikipedia/commons/6/6b/WhatsApp.svg" alt="WhatsApp" />
  </a>

  <!-- Footer Placeholder -->
  <div id="footer-placeholder"></div>

  <script src="https://cdn.emailjs.com/dist/email.min.js"></script>
  <script src="js/main.js"></script>
  <script src="js/email.js"></script>
</body>
</html>